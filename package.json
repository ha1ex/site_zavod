{
  "name": "kaiten-content-factory",
  "version": "0.1.0",
  "private": true,
  "description": "LLM harness for generating SaaS landing pages with Storybook, design system, validators, and SVG hero illustrations.",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "node scripts/setup-githooks.mjs",
    "dev": "pnpm --filter @kaiten/web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @kaiten/web start",
    "storybook": "pnpm --filter @kaiten/ui storybook",
    "harness": "pnpm --filter @kaiten/harness cli",
    "pipeline:docs": "node scripts/pipeline-docs.mjs",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@tailwindcss/oxide"
    ]
  }
}
