# ─────────────────────────────────────────────────────────────────────────
# Контент-завод Кайтен — режимы работы
# ─────────────────────────────────────────────────────────────────────────
#
# По умолчанию используется AGENT-MODE: пайплайн запускается из хост-агента
# (Claude Code, Codex, ChatGPT с file access), а сам хост и есть LLM.
# В этом режиме .env.local НЕ НУЖЕН — оставляй файл пустым или вообще не
# создавай. Команды:
#
#   pnpm -w run harness agent build landing --slug <slug> --brief content/briefs/<slug>.json
#   # ... агент заполняет prompt'ы фаз P0–P8, spec появляется в content/landings/<slug>.json ...
#   pnpm -w run harness agent apply landing --slug <slug> --brief content/briefs/<slug>.json
#
# Если хочешь использовать ВНЕШНИЙ API (старый flow `harness generate`),
# раскомментируй и заполни одну из секций ниже.

# ── Опционально: вариант 1 — Vercel AI Gateway (рекомендуется для внешнего API)
# AI_PROVIDER=anthropic         # anthropic | openai
# AI_GATEWAY=auto               # gateway | direct | auto
# AI_GATEWAY_API_KEY=
# (альтернатива ключу: VERCEL_OIDC_TOKEN из `vercel env pull`)

# ── Опционально: вариант 2 — прямой ключ провайдера
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4.7
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5

# Repair loop (для прямого API-flow `harness generate`)
# HARNESS_MAX_REPAIR_ITERATIONS=3

# Visual regression strategy: auto | playwright | storybook | none
# VISUAL_REGRESSION=auto
